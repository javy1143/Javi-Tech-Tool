function Invoke-DeleteTempFiles {
    param($OutputBox, $StatusLabel)
    Write-Log -Message "--- Deleting Temporary Files ---" -OutputBox $OutputBox -Color 'Gold' -StatusLabel $StatusLabel
    $paths = "C:\Windows\Temp", $env:TEMP
    foreach ($p in $paths) {
        Write-Log -Message "Cleaning folder: $p" -OutputBox $OutputBox -Color 'Cyan' -StatusLabel $StatusLabel
        Get-ChildItem -Path $p -Recurse -Force -ErrorAction SilentlyContinue | Remove-Item -Force -Recurse -ErrorAction SilentlyContinue
    }
    Write-Log -Message "Temporary file cleanup complete." -OutputBox $OutputBox -StatusLabel $StatusLabel
}

