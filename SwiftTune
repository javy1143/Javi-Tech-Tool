        param($ManifestPath, $OutputBox, $StatusLabel)
        Restore-FromManifest -ManifestPath $ManifestPath -OutputBox $OutputBox -StatusLabel $StatusLabel
        try { & powercfg.exe /hibernate on 2>&1 | Out-Null } catch { }
        Write-Log -Message "Hibernate re-enabled. hiberfile.sys will be recreated on next sleep." -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
    }

