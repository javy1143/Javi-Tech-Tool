#================================================================================================
# 4. EVENT HANDLERS
# This section defines what happens when you click the buttons.
#================================================================================================

$btn_select_all.Add_Click({
    $checkboxes.Values | ForEach-Object { $_.Checked = $true }
})

$btn_deselect_all.Add_Click({
    $checkboxes.Values | ForEach-Object { $_.Checked = $false }
})

# --- Modified Apply Button Click Event with Confirmation Dialogs and Status Bar Updates ---
$btn_apply.Add_Click({
    # Store original text for restoration
    $originalButtonText = $btn_apply.Text

    # Disable button to prevent multiple clicks during execution
    $btn_apply.Enabled = $false
    $output_box.Clear()
    $status_label.Text = "" # Clear status bar at start

    Write-Log -Message "Starting optimizations..." -OutputBox $output_box -StatusLabel $status_label

    # Execute checked functions in order with progress updates and confirmations
    if ($checkboxes["Delete Temporary Files"].Checked) {
        $dialogResult = [System.Windows.Forms.MessageBox]::Show(
            "Are you sure you want to delete temporary files? This action cannot be undone.",
            "Confirm Delete Temporary Files",
            [System.Windows.Forms.MessageBoxButtons]::YesNo,
            [System.Windows.Forms.MessageBoxIcon]::Warning
        )
        if ($dialogResult -eq [System.Windows.Forms.DialogResult]::Yes) {
            $btn_apply.Text = "Working: Deleting Temp Files..." # Progress update
            [System.Windows.Forms.Application]::DoEvents() # Force GUI refresh
            Invoke-DeleteTempFiles -OutputBox $output_box -StatusLabel $status_label
        } else {
            Write-Log -Message "Skipped: Delete Temporary Files (User Cancelled)" -OutputBox $output_box -Color 'Orange' -StatusLabel $status_label
        }
    }

    if ($checkboxes["Disable Hibernation"].Checked) {
        $dialogResult = [System.Windows.Forms.MessageBox]::Show(
            "Disabling hibernation will free up disk space but remove the ability to use the Hibernate power option. Are you sure?",
            "Confirm Disable Hibernation",
            [System.Windows.Forms.MessageBoxButtons]::YesNo,
            [System.Windows.Forms.MessageBoxIcon]::Warning
        )
        if ($dialogResult -eq [System.Windows.Forms.DialogResult]::Yes) {
            $btn_apply.Text = "Working: Disabling Hibernation..." # Progress update
            [System.Windows.Forms.Application]::DoEvents()
            Invoke-DisableHibernation -OutputBox $output_box -StatusLabel $status_label
        } else {
            Write-Log -Message "Skipped: Disable Hibernation (User Cancelled)" -OutputBox $output_box -Color 'Orange' -StatusLabel $status_label
        }
    }

    if ($checkboxes["Optimize Services"].Checked) {
        $btn_apply.Text = "Working: Optimizing Services..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-OptimizeServices -OutputBox $output_box -StatusLabel $status_label
    }
    if ($checkboxes["Disable Telemetry & Consumer Features"].Checked) {
        $btn_apply.Text = "Working: Disabling Telemetry..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-DisableTelemetry -OutputBox $output_box -StatusLabel $status_label
    }
    if ($checkboxes["Disable Activity History"].Checked) {
        $btn_apply.Text = "Working: Disabling Activity History..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-DisableActivityHistory -OutputBox $output_box -StatusLabel $status_label
    }
    if ($checkboxes["Disable Game DVR"].Checked) {
        $btn_apply.Text = "Working: Disabling Game DVR..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-DisableGameDVR -OutputBox $output_box -StatusLabel $status_label
    }
    if ($checkboxes["Disable Background Apps"].Checked) {
        $btn_apply.Text = "Working: Disabling Background Apps..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-DisableBackgroundApps -OutputBox $output_box -StatusLabel $status_label
    }
    if ($checkboxes["Disable Storage Sense"].Checked) {
        $btn_apply.Text = "Working: Disabling Storage Sense..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-DisableStorageSense -OutputBox $output_box -StatusLabel $status_label
    }
    if ($checkboxes["Disable WiFi Sense"].Checked) {
        $btn_apply.Text = "Working: Disabling WiFi Sense..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-DisableWifiSense -OutputBox $output_box -StatusLabel $status_label
    }
    if ($checkboxes["Disable Teredo"].Checked) {
        $btn_apply.Text = "Working: Disabling Teredo..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-DisableTeredo -OutputBox $output_box -StatusLabel $status_label
    }
    if ($checkboxes["Disable Recall (Windows 11)"].Checked) {
        $dialogResult = [System.Windows.Forms.MessageBox]::Show(
            "Disabling Windows Recall is a significant system change. Are you sure you want to proceed?",
            "Confirm Disable Windows Recall",
            [System.Windows.Forms.MessageBoxButtons]::YesNo,
            [System.Windows.Forms.MessageBoxIcon]::Warning
        )
        if ($dialogResult -eq [System.Windows.Forms.DialogResult]::Yes) {
            $btn_apply.Text = "Working: Disabling Recall..." # Progress update
            [System.Windows.Forms.Application]::DoEvents()
            Invoke-DisableRecall -OutputBox $output_box -StatusLabel $status_label
        } else {
            Write-Log -Message "Skipped: Disable Recall (Windows 11) (User Cancelled)" -OutputBox $output_box -Color 'Orange' -StatusLabel $status_label
        }
    }
    if ($checkboxes["Debloat Microsoft Edge"].Checked) {
        $btn_apply.Text = "Working: Debloating Edge..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-DebloatEdge -OutputBox $output_box -StatusLabel $status_label
    }
    if ($checkboxes["Adobe Debloat"].Checked) {
        $btn_apply.Text = "Working: Debloating Adobe..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-AdobeDebloat -OutputBox $output_box -StatusLabel $status_label
    }
    # NEW: Call Network Optimizations if checked
    if ($checkboxes["Network Optimizations"].Checked) {
        $btn_apply.Text = "Working: Optimizing Network..." # Progress update
        [System.Windows.Forms.Application]::DoEvents()
        Invoke-NetworkOptimizations -OutputBox $output_box -StatusLabel $status_label
    }
    
    Write-Log -Message "--- ALL TASKS COMPLETE ---" -OutputBox $output_box -Color 'Gold' -StatusLabel $status_label

    # Re-enable button and restore original text
    $btn_apply.Enabled = $true
    $btn_apply.Text = $originalButtonText
    $status_label.Text = "All tasks completed successfully." # Final status message
})

