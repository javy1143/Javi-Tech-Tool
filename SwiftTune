    -Risk "Medium" -GetState { "N-A" } `
    -Apply {
        param($BackupCtx,$OutputBox,$StatusLabel)
        Write-Log -Message "--- Clear Outlook Temp Attachments ---" -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel
        $versions = @("16.0","15.0","14.0")
        $folders = @()
        foreach ($v in $versions) {
            $key = "HKCU:\Software\Microsoft\Office\$v\Outlook\Security"
            try {
                $info = Get-RegValueInfo -Path $key -Name "OutlookSecureTempFolder"
                if ($info.ExistsValue -and $info.Value) { $folders += [string]$info.Value }
            } catch { }
        }
        $folders += (Join-Path $env:LOCALAPPDATA "Microsoft\Windows\INetCache\Content.Outlook")
        $folders = $folders | Where-Object { $_ -and $_.Trim().Length -gt 0 } | Select-Object -Unique
        foreach ($f in $folders) {
            if (Test-Path -LiteralPath $f) {
                try { Get-ChildItem -LiteralPath $f -Force -ErrorAction SilentlyContinue | ForEach-Object { Remove-Item -LiteralPath $_.FullName -Recurse -Force -ErrorAction SilentlyContinue } } catch { }
            }
        }
        Write-Log -Message "Outlook temp attachment cache cleared." -OutputBox $OutputBox -Color LightGreen -StatusLabel $StatusLabel
    } `
