function Invoke-DisableRecall {
    param($OutputBox, $StatusLabel)
    Write-Log -Message "--- Disabling Windows Recall Feature ---" -OutputBox $OutputBox -Color 'Gold' -StatusLabel $StatusLabel
    try {
        Set-RegValue -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WindowsAI" -Name "DisableAIDataAnalysis" -Value 1 -OutputBox $OutputBox -StatusLabel $StatusLabel
        Write-Log -Message "Executing DISM to disable Recall feature. This may take a moment..." -OutputBox $OutputBox -Color 'Cyan' -StatusLabel $StatusLabel
        $process = Start-Process "DISM.exe" -ArgumentList "/Online /Disable-Feature /FeatureName:Recall" -Wait -PassThru -NoNewWindow
        if ($process.ExitCode -eq 0 -or $process.ExitCode -eq 3010) { # 3010 means success, restart required
            Write-Log -Message "Successfully disabled Windows Recall feature. A restart may be required." -OutputBox $OutputBox -Color 'LimeGreen' -StatusLabel $StatusLabel
        } else {
            Write-Log -Message "ERROR: DISM failed to disable Recall. Exit code: $($process.ExitCode)" -OutputBox $OutputBox -Color 'Red' -StatusLabel $StatusLabel
        }
    } catch {
        Write-Log -Message "ERROR: An exception occurred while disabling Recall. Details: $($_.Exception.Message)" -OutputBox $OutputBox -Color 'Red' -StatusLabel $StatusLabel
    }
}

