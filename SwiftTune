$Script:Tweaks += New-Tweak `
    -Id "privacy_backgroundapps" `
    -Name "Reduce Background Apps (Safelist: Core Business Apps)" `
    -Category "Privacy" `
    -Risk "Medium" `
    -Description "Disables background execution for common consumer Store apps. Safelists: M365, Teams, RingCentral, OneDrive, SharePoint, and Outlook." `
    -GetState {
        $globalOk = Compare-RegExpected "HKCU:\Software\Microsoft\Windows\CurrentVersion\BackgroundAccessApplications" "GlobalUserDisabled" 0
        $consumer = @(
            "Microsoft.BingNews","Microsoft.BingWeather","Microsoft.GetHelp","Microsoft.Getstarted","Microsoft.MicrosoftSolitaireCollection",
            "Microsoft.People","Microsoft.WindowsFeedbackHub","Microsoft.XboxApp","Microsoft.XboxGameOverlay","Microsoft.XboxGamingOverlay",
            "Microsoft.XboxIdentityProvider","Microsoft.XboxSpeechToTextOverlay","Microsoft.ZuneMusic","Microsoft.ZuneVideo","Microsoft.YourPhone","Microsoft.Todos"
        )
        $pkgs = @(Get-AppxPackage -ErrorAction SilentlyContinue)
        $targets = @($pkgs | Where-Object { $consumer -contains $_.Name })
        if ($targets.Count -eq 0) { if ($globalOk) { "N-A" } else { "NotApplied" } }
        else {
            $ok = 0
            foreach ($p in $targets) {
                $k = "HKCU:\Software\Microsoft\Windows\CurrentVersion\BackgroundAccessApplications\$($p.PackageFamilyName)"
                if (Compare-RegExpected $k "Disabled" 1) { $ok++ }
            }
            $ratio = $ok / [double]$targets.Count
            if ($globalOk -and ($ratio -ge 0.9)) { "Applied" }
            elseif ((-not $globalOk) -and ($ok -eq 0)) { "NotApplied" }
            else { "Partial" }
        }
    } `
    -Apply {
        param($BackupCtx,$OutputBox,$StatusLabel)
        Write-Log -Message "--- Reduce Background Apps (Safelist: Core Business Apps) ---" -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel
        Set-RegValue -BackupCtx $BackupCtx -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\BackgroundAccessApplications" -Name "GlobalUserDisabled" -Value 0 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel

        $consumer = @(
            "Microsoft.BingNews","Microsoft.BingWeather","Microsoft.GetHelp","Microsoft.Getstarted","Microsoft.MicrosoftSolitaireCollection",
            "Microsoft.People","Microsoft.WindowsFeedbackHub","Microsoft.XboxApp","Microsoft.XboxGameOverlay","Microsoft.XboxGamingOverlay",
            "Microsoft.XboxIdentityProvider","Microsoft.XboxSpeechToTextOverlay","Microsoft.ZuneMusic","Microsoft.ZuneVideo","Microsoft.YourPhone","Microsoft.Todos"
        )
        # ADDED STRICT GUARDRAILS FOR M365 SUITE
        $allowPatterns = @("MSTeams","Teams","RingCentral","OneDrive","Outlook","Office","SharePoint")
        $pkgs = @(Get-AppxPackage -ErrorAction SilentlyContinue)
        $changed = 0

        foreach ($p in $pkgs) {
            $pf = [string]$p.PackageFamilyName
            $name = [string]$p.Name
            $isAllow = $false
            foreach ($pat in $allowPatterns) { if ($pf -like "*$pat*" -or $name -like "*$pat*") { $isAllow = $true; break } }

            if (-not $isAllow -and -not ($consumer -contains $name)) { continue }

            $k = "HKCU:\Software\Microsoft\Windows\CurrentVersion\BackgroundAccessApplications\$pf"
            if ($isAllow) {
                Set-RegValue -BackupCtx $BackupCtx -Path $k -Name "Disabled" -Value 0 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel
                Set-RegValue -BackupCtx $BackupCtx -Path $k -Name "DisabledByUser" -Value 0 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel
            } else {
                Set-RegValue -BackupCtx $BackupCtx -Path $k -Name "Disabled" -Value 1 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel
                Set-RegValue -BackupCtx $BackupCtx -Path $k -Name "DisabledByUser" -Value 1 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel
            }
            $changed++
        }

        Write-Log -Message ("Background apps updated for {0} packages." -f $changed) -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel
    } `
    -Undo { param($ManifestPath,$OutputBox,$StatusLabel) Restore-FromManifest -ManifestPath $ManifestPath -OutputBox $OutputBox -StatusLabel $StatusLabel }

