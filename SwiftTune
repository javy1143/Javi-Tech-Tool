# --- Privacy tweaks ---
$Script:Tweaks += New-Tweak `
    -Id "privacy_activity" -Name "Disable Activity History" -Category "Privacy" `
    -Description "Disables Activity Feed and prevents publishing/uploading user activities." `
    -GetState {
        $p="HKLM:\SOFTWARE\Policies\Microsoft\Windows\System"
        $a=Compare-RegExpected $p "EnableActivityFeed" 0
        $b=Compare-RegExpected $p "PublishUserActivities" 0
        $c=Compare-RegExpected $p "UploadUserActivities" 0
        if ($a -and $b -and $c) { "Applied" } elseif (-not $a -and -not $b -and -not $c) { "NotApplied" } else { "Partial" }
    } `
    -Apply {
        param($BackupCtx,$OutputBox,$StatusLabel)
        Write-Log -Message "--- Disable Activity History ---" -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel
        $p="HKLM:\SOFTWARE\Policies\Microsoft\Windows\System"
        Set-RegValue -BackupCtx $BackupCtx -Path $p -Name "EnableActivityFeed" -Value 0 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel
        Set-RegValue -BackupCtx $BackupCtx -Path $p -Name "PublishUserActivities" -Value 0 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel
        Set-RegValue -BackupCtx $BackupCtx -Path $p -Name "UploadUserActivities" -Value 0 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel
    } `
    -Undo { param($ManifestPath,$OutputBox,$StatusLabel) Restore-FromManifest -ManifestPath $ManifestPath -OutputBox $OutputBox -StatusLabel $StatusLabel }

