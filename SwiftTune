        foreach ($p in $adobeProcs) { try { Stop-Process -Name $p -Force -ErrorAction SilentlyContinue } catch { } }
        Start-Sleep -Milliseconds 1000
        $acrobatVersions = @("DC","2020","2017","2015","11.0")
        $cleared = 0
        foreach ($ver in $acrobatVersions) {
            $cachePaths = @(
                (Join-Path $env:APPDATA    "Adobe\Acrobat\$ver\Cache"),
                (Join-Path $env:LOCALAPPDATA "Adobe\Acrobat\$ver\Cache"),
                (Join-Path $env:LOCALAPPDATA "Adobe\Acrobat\$ver\ConnectorIcons"),
                (Join-Path $env:LOCALAPPDATA "Temp\Adobe"),
                (Join-Path $env:LOCALAPPDATA "Adobe\Linguistics\Providers")
            )
            foreach ($cp in $cachePaths) {
                if (Test-Path -LiteralPath $cp) {
                    try {
                        Get-ChildItem -LiteralPath $cp -Force -ErrorAction SilentlyContinue | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue
                        Write-Log -Message "Cleared: $cp" -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel
                        $cleared++
                    } catch { }
                }
            }
        }
        $sharedTemp = Join-Path $env:LOCALAPPDATA "Temp\Adobe Acrobat"
        if (Test-Path -LiteralPath $sharedTemp) {
            try { Remove-Item -LiteralPath $sharedTemp -Recurse -Force -ErrorAction SilentlyContinue; $cleared++ } catch { }
        }
        if ($cleared -eq 0) { Write-Log -Message "No Adobe Acrobat cache paths found for this user." -OutputBox $OutputBox -Color Yellow -StatusLabel $StatusLabel }
        else { Write-Log -Message "Adobe Acrobat cache cleared ($cleared paths)." -OutputBox $OutputBox -Color LightGreen -StatusLabel $StatusLabel }
        Write-DiskDelta -Before $before -OutputBox $OutputBox -StatusLabel $StatusLabel
    } `
    -Undo { param($ManifestPath,$OutputBox,$StatusLabel) Write-Log -Message "Adobe cache clearing is not reversible." -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel }

