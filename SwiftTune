#------------------------------------------------------------------------------------------------
# 4) UI-safe Logging Helpers
#------------------------------------------------------------------------------------------------
function Write-Log {
    param(
        [Parameter(Mandatory=$true)][string]$Message,
        [Parameter(Mandatory=$true)][System.Windows.Forms.RichTextBox]$OutputBox,
        [System.Drawing.Color]$Color = [System.Drawing.Color]::White,
        [System.Windows.Forms.ToolStripStatusLabel]$StatusLabel = $null
    )

    $ts = (Get-Date).ToString("HH:mm:ss")
    $line = "$ts - $Message`r`n"

    $uiWork = [System.Windows.Forms.MethodInvoker]{
        try {
            $OutputBox.SelectionStart = $OutputBox.TextLength
            $OutputBox.SelectionLength = 0
            $OutputBox.SelectionColor = $Color
            $OutputBox.AppendText($line)
            $OutputBox.ScrollToCaret()
            $OutputBox.Refresh()

            if ($StatusLabel) { $StatusLabel.Text = $Message }
        } catch { }
    }

    try {
        if ($OutputBox.InvokeRequired) {
            [void]$OutputBox.BeginInvoke($uiWork)
        } else {
            $uiWork.Invoke()
        }
    } catch {
        try { Write-Host $Message } catch { }
        return
    }
    try { Write-Host $Message } catch { }
}

#------------------------------------------------------------------------------------------------
# 5) Registry Utilities (type-safe)
#------------------------------------------------------------------------------------------------
function Invoke-ProcessLogged {
    param(
        [Parameter(Mandatory=$true)][string]$FilePath,
        [Parameter(Mandatory=$true)][string]$Arguments,
        [Parameter(Mandatory=$true)][string]$Title,
        [Parameter(Mandatory=$true)][System.Windows.Forms.RichTextBox]$OutputBox,
        [Parameter(Mandatory=$true)][System.Windows.Forms.ToolStripStatusLabel]$StatusLabel
    )
    Write-Log -Message "$($Title): starting..." -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel

    $psi = New-Object System.Diagnostics.ProcessStartInfo
    $psi.FileName = $FilePath
    $psi.Arguments = $Arguments
    $psi.RedirectStandardOutput = $true
    $psi.RedirectStandardError  = $true
    $psi.UseShellExecute = $false
    $psi.CreateNoWindow  = $true

    $p = New-Object System.Diagnostics.Process
    $p.StartInfo = $psi

    try {
        [void]$p.Start()
    } catch {
        throw "Failed to start process '$FilePath'. $($_.Exception.Message)"
    }

    while (-not $p.HasExited) {
        try {
            while (-not $p.StandardOutput.EndOfStream) {
                $line = $p.StandardOutput.ReadLine()
                if ($null -ne $line -and $line.Trim().Length -gt 0) {
                    Write-Log -Message $line -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel
                }
            }
            while (-not $p.StandardError.EndOfStream) {
                $eline = $p.StandardError.ReadLine()
                if ($null -ne $eline -and $eline.Trim().Length -gt 0) {
                    Write-Log -Message $eline -OutputBox $OutputBox -Color Salmon -StatusLabel $StatusLabel
                }
            }
        } catch { }

        if ($Script:ApplyRun -and $Script:ApplyRun.CancelRequested) {
            try { $p.Kill() } catch { }
            throw "Cancelled."
        }

        [System.Windows.Forms.Application]::DoEvents()
        Start-Sleep -Milliseconds 75
    }

    try {
        while (-not $p.StandardOutput.EndOfStream) {
            $line = $p.StandardOutput.ReadLine()
            if ($null -ne $line -and $line.Trim().Length -gt 0) {
                Write-Log -Message $line -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel
            }
        }
        while (-not $p.StandardError.EndOfStream) {
            $eline = $p.StandardError.ReadLine()
            if ($null -ne $eline -and $eline.Trim().Length -gt 0) {
                Write-Log -Message $eline -OutputBox $OutputBox -Color Salmon -StatusLabel $StatusLabel
            }
        }
    } catch { }

    Write-Log -Message "$($Title): completed (exit code $($p.ExitCode))." -OutputBox $OutputBox -Color LightGreen -StatusLabel $StatusLabel
    return $p.ExitCode
}

function Convert-RegistryPath {
    param([Parameter(Mandatory=$true)][string]$Path)

    $p = $Path.Trim()
    if ($p -match '^(HKLM|HKEY_LOCAL_MACHINE):\\') { return @{ Hive = "LocalMachine"; SubKey = $p -replace '^(HKLM|HKEY_LOCAL_MACHINE):\\','' } }
    if ($p -match '^(HKCU|HKEY_CURRENT_USER):\\')  { return @{ Hive = "CurrentUser";  SubKey = $p -replace '^(HKCU|HKEY_CURRENT_USER):\\','' } }
    if ($p -match '^(HKCR|HKEY_CLASSES_ROOT):\\')  { return @{ Hive = "ClassesRoot";  SubKey = $p -replace '^(HKCR|HKEY_CLASSES_ROOT):\\','' } }
    if ($p -match '^(HKU|HKEY_USERS):\\')          { return @{ Hive = "Users";       SubKey = $p -replace '^(HKU|HKEY_USERS):\\','' } }
    if ($p -match '^(HKCC|HKEY_CURRENT_CONFIG):\\'){ return @{ Hive = "CurrentConfig";SubKey = $p -replace '^(HKCC|HKEY_CURRENT_CONFIG):\\','' } }

    throw "Unsupported registry root in path: $Path"
}

function Ensure-RegKey { param([Parameter(Mandatory=$true)][string]$Path)
    if (-not (Test-Path -LiteralPath $Path)) { New-Item -Path $Path -Force | Out-Null }
}

function Get-RegValueInfo {
    param([Parameter(Mandatory=$true)][string]$Path,[Parameter(Mandatory=$true)][string]$Name)
    $conv = Convert-RegistryPath -Path $Path
    $hive = [Microsoft.Win32.Registry]::$($conv.Hive)
    $key  = $hive.OpenSubKey($conv.SubKey, $false)
    if (-not $key) { return [pscustomobject]@{ ExistsKey=$false; ExistsValue=$false; Value=$null; Kind=$null } }
    try {
        if ($key.GetValueNames() -notcontains $Name) { return [pscustomobject]@{ ExistsKey=$true; ExistsValue=$false; Value=$null; Kind=$null } }
        $val  = $key.GetValue($Name, $null, [Microsoft.Win32.RegistryValueOptions]::DoNotExpandEnvironmentNames)
        $kind = $key.GetValueKind($Name).ToString()
        return [pscustomobject]@{ ExistsKey=$true; ExistsValue=$true; Value=$val; Kind=$kind }
    } finally { $key.Close() }
}

function Set-RegValueSafe {
    param(
        [Parameter(Mandatory=$true)][string]$Path,
        [Parameter(Mandatory=$true)][string]$Name,
        [Parameter(Mandatory=$true)]$Value,
        [Parameter(Mandatory=$true)][ValidateSet("DWord","QWord","String","ExpandString","MultiString","Binary")][string]$Type
    )
    Ensure-RegKey -Path $Path
    $conv = Convert-RegistryPath -Path $Path
    $hive = [Microsoft.Win32.Registry]::$($conv.Hive)
    $key  = $hive.CreateSubKey($conv.SubKey)
    try { $key.SetValue($Name, $Value, ([Microsoft.Win32.RegistryValueKind]::$Type)) }
    finally { $key.Close() }
}

function Remove-RegValueSafe {
    param([Parameter(Mandatory=$true)][string]$Path,[Parameter(Mandatory=$true)][string]$Name)
    $conv = Convert-RegistryPath -Path $Path
    $hive = [Microsoft.Win32.Registry]::$($conv.Hive)
    $key  = $hive.OpenSubKey($conv.SubKey, $true)
    if (-not $key) { return }
    try { if ($key.GetValueNames() -contains $Name) { $key.DeleteValue($Name, $false) } }
    finally { $key.Close() }
}

#------------------------------------------------------------------------------------------------
# 6) Backup Context + Restore
#------------------------------------------------------------------------------------------------
function New-BackupContext {
    [ordered]@{
        Registry = @{}  
        Services = @{}  
        Tasks    = @{}  
        Files    = @{}  
        Features = @{}  
    }
}

function Backup-RegValue { param([hashtable]$Ctx,[string]$Path,[string]$Name)
    $k = "$Path|$Name"
    if (-not $Ctx.Registry.ContainsKey($k)) {
        $info = Get-RegValueInfo -Path $Path -Name $Name
        $Ctx.Registry[$k] = [ordered]@{
            Path=$Path; Name=$Name
            ExistsKey=$info.ExistsKey; ExistsValue=$info.ExistsValue
            Value=$info.Value; Kind=$info.Kind
        }
    }
}

function Restore-RegValue { param([hashtable]$Record)
    if (-not $Record.ExistsKey -or -not $Record.ExistsValue) {
        Remove-RegValueSafe -Path $Record.Path -Name $Record.Name
        return
    }
    $kind = if ($Record.Kind) { [string]$Record.Kind } else { "String" }
    Set-RegValueSafe -Path $Record.Path -Name $Record.Name -Value $Record.Value -Type $kind
}

function Get-ServiceStartupInfo {
    param([Parameter(Mandatory=$true)][string]$Name)
    try {
        $svc = Get-CimInstance -ClassName Win32_Service -Filter "Name='$Name'"
        if (-not $svc) { return [pscustomobject]@{ Exists=$false } }
        $delayed = $false
        try {
            $reg = Get-RegValueInfo -Path "HKLM:\SYSTEM\CurrentControlSet\Services\$Name" -Name "DelayedAutostart"
            if ($reg.ExistsValue -and ([int]$reg.Value -eq 1)) { $delayed = $true }
        } catch { }
        $startup = switch ($svc.StartMode) {
            "Auto"     { if ($delayed) { "AutomaticDelayedStart" } else { "Automatic" } }
            "Manual"   { "Manual" }
            "Disabled" { "Disabled" }
            default    { "Manual" }
        }
        return [pscustomobject]@{ Exists=$true; StartupType=$startup; DelayedAutoStart=$delayed }
    } catch { return [pscustomobject]@{ Exists=$false } }
}

function Backup-Service { param([hashtable]$Ctx,[string]$Name)
    if (-not $Ctx.Services.ContainsKey($Name)) {
        $info = Get-ServiceStartupInfo -Name $Name
        $Ctx.Services[$Name] = [ordered]@{
            Name=$Name
            Exists=[bool]$info.Exists
            StartupType= if ($info.Exists) { $info.StartupType } else { $null }
            DelayedAutoStart= if ($info.Exists) { [bool]$info.DelayedAutoStart } else { $null }
        }
    }
}

function Set-ServiceStartupTypeSafe {
    param([Parameter(Mandatory=$true)][string]$Name,[Parameter(Mandatory=$true)][ValidateSet("Automatic","Manual","Disabled","AutomaticDelayedStart")][string]$StartupType)
    if ($StartupType -eq "AutomaticDelayedStart") {
        Set-Service -Name $Name -StartupType Automatic
        Set-RegValueSafe -Path "HKLM:\SYSTEM\CurrentControlSet\Services\$Name" -Name "DelayedAutostart" -Value 1 -Type DWord
    } else {
        Set-Service -Name $Name -StartupType $StartupType
        try { Set-RegValueSafe -Path "HKLM:\SYSTEM\CurrentControlSet\Services\$Name" -Name "DelayedAutostart" -Value 0 -Type DWord } catch { }
    }
}

function Restore-Service { param([hashtable]$Record)
    if (-not $Record.Exists) { return }
    if (-not $Record.StartupType) { return }
    Set-ServiceStartupTypeSafe -Name $Record.Name -StartupType $Record.StartupType
}

function Split-TaskFullName {
    param([Parameter(Mandatory=$true)][string]$FullName)
    $n = $FullName.Trim()
    if (-not $n.StartsWith("\")) { $n = "\" + $n }
    $idx = $n.LastIndexOf("\")
    if ($idx -lt 1) { throw "Invalid task name: $FullName" }
    [pscustomobject]@{
        FullName=$n
        TaskPath=$n.Substring(0,$idx+1)
        TaskName=$n.Substring($idx+1)
    }
}

function Get-TaskStateSafe { param([Parameter(Mandatory=$true)][string]$FullName)
    try {
        $split = Split-TaskFullName -FullName $FullName
        $t = Get-ScheduledTask -TaskPath $split.TaskPath -TaskName $split.TaskName -ErrorAction Stop
        [pscustomobject]@{ Exists=$true; State=$t.State.ToString() }
    } catch { [pscustomobject]@{ Exists=$false; State=$null } }
}

function Backup-Task { param([hashtable]$Ctx,[string]$FullName)
    if (-not $Ctx.Tasks.ContainsKey($FullName)) {
        $info = Get-TaskStateSafe -FullName $FullName
        $Ctx.Tasks[$FullName] = [ordered]@{
            FullName=(Split-TaskFullName -FullName $FullName).FullName
            Exists=[bool]$info.Exists
            State=$info.State
        }
    }
}

function Disable-TaskRobust { param([Parameter(Mandatory=$true)][string]$FullName)
    $split = Split-TaskFullName -FullName $FullName
    try { Disable-ScheduledTask -TaskPath $split.TaskPath -TaskName $split.TaskName -ErrorAction Stop | Out-Null }
    catch { & schtasks.exe /Change /TN $split.FullName /Disable | Out-Null }
}

function Enable-TaskRobust { param([Parameter(Mandatory=$true)][string]$FullName)
    $split = Split-TaskFullName -FullName $FullName
    try { Enable-ScheduledTask -TaskPath $split.TaskPath -TaskName $split.TaskName -ErrorAction Stop | Out-Null }
    catch { & schtasks.exe /Change /TN $split.FullName /Enable | Out-Null }
}

function Restore-Task { param([hashtable]$Record)
    if (-not $Record.Exists) { return }
    if ($Record.State -eq "Disabled") { Disable-TaskRobust -FullName $Record.FullName }
    else { Enable-TaskRobust -FullName $Record.FullName }
}

function Get-OptionalFeatureStateSafe { param([Parameter(Mandatory=$true)][string]$Name)
    try {
        $f = Get-WindowsOptionalFeature -Online -FeatureName $Name -ErrorAction Stop
        [pscustomobject]@{ Exists=$true; State=$f.State.ToString() }
    } catch { [pscustomobject]@{ Exists=$false; State=$null } }
}

function Backup-Feature { param([hashtable]$Ctx,[string]$Name)
    if (-not $Ctx.Features.ContainsKey($Name)) {
        $info = Get-OptionalFeatureStateSafe -Name $Name
        $Ctx.Features[$Name] = [ordered]@{ Name=$Name; Exists=[bool]$info.Exists; State=$info.State }
    }
}

function Restore-Feature { param([hashtable]$Record)
    if (-not $Record.Exists) { return }
    if ($Record.State -eq "Enabled") { & DISM.exe /Online /Enable-Feature /FeatureName:$($Record.Name) /NoRestart | Out-Null }
    elseif ($Record.State -eq "Disabled") { & DISM.exe /Online /Disable-Feature /FeatureName:$($Record.Name) /NoRestart | Out-Null }
}

function Backup-FileRename {
    param([hashtable]$Ctx,[Parameter(Mandatory=$true)][string]$OriginalPath,[Parameter(Mandatory=$true)][string]$BackupPath)
    $k = "rename|$OriginalPath|$BackupPath"
    if (-not $Ctx.Files.ContainsKey($k)) {
        $Ctx.Files[$k] = [ordered]@{
            Key=$k; Kind="rename"
            OriginalPath=$OriginalPath; BackupPath=$BackupPath
            ExistsOriginal=(Test-Path -LiteralPath $OriginalPath)
            ExistsBackup=(Test-Path -LiteralPath $BackupPath)
        }
    }
}

function Restore-FileRecord {
    param([hashtable]$Record)
    if ($Record.Kind -ne "rename") { return }
    $orig = $Record.OriginalPath
    $bak  = $Record.BackupPath

    if ($Record.ExistsOriginal) {
        if (-not (Test-Path -LiteralPath $orig) -and (Test-Path -LiteralPath $bak)) {
            try { Rename-Item -LiteralPath $bak -NewName (Split-Path -Leaf $orig) -Force -ErrorAction Stop } catch { }
        }
    }
}

function Save-BackupManifest {
    param([Parameter(Mandatory=$true)][hashtable]$BackupCtx,[Parameter(Mandatory=$true)][string[]]$SelectedTweakIds)
    $ts = Get-Date -Format "yyyyMMdd_HHmmss"
    $path = Join-Path $Script:BackupRoot "backup_$ts.json"
    $manifest = [ordered]@{
        AppName=$Script:AppName; AppVersion=$Script:AppVersion
        Timestamp=(Get-Date).ToString("o")
        Computer=$env:COMPUTERNAME; User="$env:USERDOMAIN\$env:USERNAME"
        SelectedTweakIds=$SelectedTweakIds
        BackupCtx=$BackupCtx
    }
    ($manifest | ConvertTo-Json -Depth 10) | Set-Content -Path $path -Encoding UTF8
    ($path | ConvertTo-Json) | Set-Content -Path $Script:LastRunPtr -Encoding UTF8
    return $path
}

function Load-LastBackupPath {
    if (-not (Test-Path -LiteralPath $Script:LastRunPtr)) { return $null }
    try {
        $p = Get-Content -Path $Script:LastRunPtr -Raw -ErrorAction Stop | ConvertFrom-Json
        if ($p -and (Test-Path -LiteralPath $p)) { return [string]$p }
        return $null
    } catch { return $null }
}

function Restore-FromManifest {
    param([Parameter(Mandatory=$true)][string]$ManifestPath,[Parameter(Mandatory=$true)][System.Windows.Forms.RichTextBox]$OutputBox,[System.Windows.Forms.ToolStripStatusLabel]$StatusLabel=$null)

    $m = Get-Content -Path $ManifestPath -Raw | ConvertFrom-Json
    Write-Log -Message "Restoring from: $ManifestPath" -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel

    foreach ($kv in $m.BackupCtx.Registry.PSObject.Properties) { Restore-RegValue -Record $kv.Value }
    foreach ($kv in $m.BackupCtx.Services.PSObject.Properties) { Restore-Service -Record $kv.Value }
    foreach ($kv in $m.BackupCtx.Tasks.PSObject.Properties)    { Restore-Task -Record $kv.Value }
    foreach ($kv in $m.BackupCtx.Files.PSObject.Properties)    { Restore-FileRecord -Record $kv.Value }
    foreach ($kv in $m.BackupCtx.Features.PSObject.Properties) { Restore-Feature -Record $kv.Value }

    Write-Log -Message "Restore complete. A reboot may be required." -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
}

#------------------------------------------------------------------------------------------------
# 7) High-level Safe Setters (auto-backup)
#------------------------------------------------------------------------------------------------
function Set-RegValue {
    param(
        [Parameter(Mandatory=$true)][hashtable]$BackupCtx,
        [Parameter(Mandatory=$true)][string]$Path,
        [Parameter(Mandatory=$true)][string]$Name,
        [Parameter(Mandatory=$true)]$Value,
        [Parameter(Mandatory=$true)][ValidateSet("DWord","QWord","String","ExpandString","MultiString","Binary")][string]$Type,
        [System.Windows.Forms.RichTextBox]$OutputBox,
        [System.Windows.Forms.ToolStripStatusLabel]$StatusLabel
    )
    Backup-RegValue -Ctx $BackupCtx -Path $Path -Name $Name
    Set-RegValueSafe -Path $Path -Name $Name -Value $Value -Type $Type
    if ($OutputBox) { Write-Log -Message "Registry set: $Path [$Name] = $Value ($Type)" -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel }
}

function Set-ServiceStartup {
    param(
        [Parameter(Mandatory=$true)][hashtable]$BackupCtx,
        [Parameter(Mandatory=$true)][string]$Name,
        [Parameter(Mandatory=$true)][ValidateSet("Automatic","Manual","Disabled","AutomaticDelayedStart")][string]$StartupType,
        [System.Windows.Forms.RichTextBox]$OutputBox,
        [System.Windows.Forms.ToolStripStatusLabel]$StatusLabel
    )
    Backup-Service -Ctx $BackupCtx -Name $Name
    if (-not (Get-Service -Name $Name -ErrorAction SilentlyContinue)) {
        Write-Log -Message "Service not found: $Name (skipping)" -OutputBox $OutputBox -Color Yellow -StatusLabel $StatusLabel
        return
    }
    Set-ServiceStartupTypeSafe -Name $Name -StartupType $StartupType
    Write-Log -Message "Service startup set: $Name -> $StartupType" -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
}

function Disable-ScheduledTaskSafe {
    param([Parameter(Mandatory=$true)][hashtable]$BackupCtx,[Parameter(Mandatory=$true)][string]$FullName,[System.Windows.Forms.RichTextBox]$OutputBox,[System.Windows.Forms.ToolStripStatusLabel]$StatusLabel)
    Backup-Task -Ctx $BackupCtx -FullName $FullName
    Disable-TaskRobust -FullName $FullName
    Write-Log -Message "Task disabled: $FullName" -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
}

function Disable-OptionalFeatureSafe {
    param([Parameter(Mandatory=$true)][hashtable]$BackupCtx,[Parameter(Mandatory=$true)][string]$Name,[System.Windows.Forms.RichTextBox]$OutputBox,[System.Windows.Forms.ToolStripStatusLabel]$StatusLabel)
    Backup-Feature -Ctx $BackupCtx -Name $Name
    $info = Get-OptionalFeatureStateSafe -Name $Name
    if (-not $info.Exists) {
        Write-Log -Message "Optional feature not present: $Name (skipping)" -OutputBox $OutputBox -Color Yellow -StatusLabel $StatusLabel
        return
    }
    Write-Log -Message "DISM: Disabling optional feature $Name" -OutputBox $OutputBox -Color Cyan -StatusLabel $StatusLabel
    $p = Start-Process -FilePath "DISM.exe" -ArgumentList @("/Online","/Disable-Feature","/FeatureName:$Name","/NoRestart") -Wait -PassThru -WindowStyle Hidden
    if ($p.ExitCode -notin 0,3010) { throw "DISM failed disabling $Name (ExitCode=$($p.ExitCode))" }
    Write-Log -Message "Feature disabled: $Name (ExitCode=$($p.ExitCode))" -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
}

#------------------------------------------------------------------------------------------------
# 8) Tweak Catalog (data-driven)
#------------------------------------------------------------------------------------------------
function New-Tweak {
    param(
        [Parameter(Mandatory=$true)][string]$Id,
        [Parameter(Mandatory=$true)][string]$Name,
        [Parameter(Mandatory=$true)][ValidateSet("Privacy","Performance","Debloat","Maintenance")][string]$Category,
        [Parameter(Mandatory=$true)][string]$Description,
        [ValidateSet("Low","Medium","High")][string]$Risk = "Low",
        [bool]$RequiresReboot = $false,
        [scriptblock]$IsAvailable = { return $true },
        [scriptblock]$GetState = { return "Unknown" },  
        [Parameter(Mandatory=$true)][scriptblock]$Apply,
        [Parameter(Mandatory=$true)][scriptblock]$Undo
    )
    [pscustomobject]@{
        Id=$Id; Name=$Name; Category=$Category; Description=$Description
        Risk=$Risk; RequiresReboot=$RequiresReboot
        IsAvailable=$IsAvailable; GetState=$GetState
        Apply=$Apply; Undo=$Undo
    }
}

function Compare-RegExpected { param([string]$Path,[string]$Name,[object]$Expected)
    try { $i = Get-RegValueInfo -Path $Path -Name $Name; return ($i.ExistsValue -and ($i.Value -eq $Expected)) }
    catch { return $false }
}

