    $ans = [System.Windows.Forms.MessageBox]::Show("This will restore settings captured in:`r`n$p`r`n`r`nProceed?","Undo Last Run","YesNo","Warning")
    if ($ans -ne "Yes") { return }
    try {
        Restore-FromManifest -ManifestPath $p -OutputBox $outputBox -StatusLabel $statusLabel
        Refresh-TweakStates
    } catch {
        Write-Log -Message "ERROR: Restore failed -> $($_.Exception.Message)" -OutputBox $outputBox -Color Red -StatusLabel $statusLabel
    }
})

