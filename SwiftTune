$Script:Tweaks += New-Tweak `
    -Id "perf_hibernate" -Name "Disable Hibernate and Fast Startup (Reclaims ~8-16 GB)" -Category "Performance" `
    -Risk "Low" -RequiresReboot $true `
    -Description "Runs 'powercfg /h off' to delete hiberfile.sys (~8-16 GB on 16 GB machines) and disables Fast Startup. Fast Startup causes stale driver state after major upgrades — disabling it forces a clean cold boot every time. Security benefit: full kernel re-init on each shutdown." `
    -GetState {
        $hib = Get-RegValueInfo -Path "HKLM:\SYSTEM\CurrentControlSet\Control\Power" -Name "HibernateEnabled"
        if ($hib.ExistsValue -and [int]$hib.Value -eq 0) { "Applied" } else { "NotApplied" }
    } `
    -Apply {
        param($BackupCtx, $OutputBox, $StatusLabel)
        Write-Log -Message "--- Disable Hibernate + Fast Startup ---" -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel
        $before = Get-DriveFreeGB
        try {
            & powercfg.exe /hibernate off 2>&1 | Out-Null
            Write-Log -Message "Hibernate disabled. hiberfile.sys removed." -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
        } catch {
            Write-Log -Message "powercfg /hibernate off failed: $($_.Exception.Message)" -OutputBox $OutputBox -Color Salmon -StatusLabel $StatusLabel
        }
        Set-RegValue -BackupCtx $BackupCtx -Path "HKLM:\SYSTEM\CurrentControlSet\Control\Power" -Name "HibernateEnabled" -Value 0 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel
        Set-RegValue -BackupCtx $BackupCtx -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\System" -Name "HiberbootEnabled" -Value 0 -Type DWord -OutputBox $OutputBox -StatusLabel $StatusLabel
        Write-DiskDelta -Before $before -OutputBox $OutputBox -StatusLabel $StatusLabel
        Write-Log -Message "Fast Startup disabled. Machine will perform full cold boot on every shutdown." -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
    } `
