        foreach ($root in $paths | Where-Object { $_ -and (Test-Path -LiteralPath $_) }) {
            foreach ($t in $targets) {
                $p = Join-Path $root $t
                if (Test-Path -LiteralPath $p) { try { Remove-Item -LiteralPath $p -Recurse -Force -ErrorAction SilentlyContinue } catch { } }
