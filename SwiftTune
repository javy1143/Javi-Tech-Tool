$Script:Tweaks += New-Tweak `
    -Id "maint_onedrive_health" -Name "OneDrive Sync Health Diagnostic" -Category "Maintenance" -Risk "Low" `
    -Description "Read-only diagnostic: reports OneDrive sync status, account, and folder path to the log. Makes no changes." `
    -GetState { "N-A" } `
    -Apply {
        param($BackupCtx,$OutputBox,$StatusLabel)
        Write-Log -Message "--- OneDrive Sync Health Diagnostic ---" -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel
        $odExe = "$env:LOCALAPPDATA\Microsoft\OneDrive\OneDrive.exe"
        if (-not (Test-Path -LiteralPath $odExe)) {
            Write-Log -Message "OneDrive executable not found at $odExe." -OutputBox $OutputBox -Color Yellow -StatusLabel $StatusLabel
            return
        }
        $odProc = Get-Process -Name "OneDrive" -ErrorAction SilentlyContinue
        if ($odProc) {
            Write-Log -Message "OneDrive process: Running (PID $($odProc.Id))" -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
        } else {
            Write-Log -Message "OneDrive process: NOT running." -OutputBox $OutputBox -Color Yellow -StatusLabel $StatusLabel
        }
        try {
            $syncRoot = (Get-RegValueInfo -Path "HKCU:\Software\Microsoft\OneDrive\Accounts\Business1" -Name "UserFolder").Value
            if ($syncRoot) { Write-Log -Message "OneDrive Business sync folder: $syncRoot" -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel }
        } catch { }
        try {
            $personalRoot = (Get-RegValueInfo -Path "HKCU:\Software\Microsoft\OneDrive\Accounts\Personal" -Name "UserFolder").Value
            if ($personalRoot) { Write-Log -Message "OneDrive Personal sync folder: $personalRoot" -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel }
        } catch { }
        $syncStatKeys = @(
            "HKCU:\Software\Microsoft\OneDrive\Accounts\Business1",
            "HKCU:\Software\Microsoft\OneDrive\Accounts\Personal"
        )
        foreach ($k in $syncStatKeys) {
            try {
                $email = (Get-RegValueInfo -Path $k -Name "UserEmail").Value
                $lastSynced = (Get-RegValueInfo -Path $k -Name "LastSyncedTimestamp").Value
                if ($email) { Write-Log -Message "Account: $email | Last synced: $lastSynced" -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel }
            } catch { }
        }
        try {
            if ($syncRoot -and (Test-Path -LiteralPath $syncRoot)) {
                $size = [math]::Round((Get-ChildItem -LiteralPath $syncRoot -Recurse -Force -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum -ErrorAction SilentlyContinue).Sum / 1GB, 2)
                Write-Log -Message "OneDrive local data size: $size GB" -OutputBox $OutputBox -Color Cyan -StatusLabel $StatusLabel
            }
        } catch { }
        Write-Log -Message "OneDrive health diagnostic complete." -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
    } `
    -Undo { param($ManifestPath,$OutputBox,$StatusLabel) Write-Log -Message "Diagnostic only — no undo needed." -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel }

