# --- NEW Tweak Function: Network Optimizations ---
function Invoke-NetworkOptimizations {
    param($OutputBox, $StatusLabel)
    Write-Log -Message "--- Applying Network Optimizations ---" -OutputBox $OutputBox -Color 'Gold' -StatusLabel $StatusLabel

    # Disable Nagle's Algorithm (can reduce latency for some applications, especially games)
    # This affects TCP connections and can sometimes cause issues with older applications.
    # It's typically applied per network adapter or globally.
    # For simplicity, we'll apply it to the default TCP parameters.
    $tcpip_params_path = "HKLM:\SYSTEM\CurrentControlSet\Services\Tcpip\Parameters"
    $interfaces_path = "HKLM:\SYSTEM\CurrentControlSet\Services\Tcpip\Parameters\Interfaces"

    Write-Log -Message "Disabling Nagle's Algorithm (TcpNoDelay)..." -OutputBox $OutputBox -Color 'Cyan' -StatusLabel $StatusLabel
    Set-RegValue -Path $tcpip_params_path -Name "TcpNoDelay" -Value 1 -OutputBox $OutputBox -StatusLabel $StatusLabel

    # Apply TcpNoDelay to all network interfaces (more robust)
    try {
        Get-ChildItem -Path $interfaces_path | ForEach-Object {
            $interfacePath = $_.PSPath
            Write-Log -Message "Setting TcpNoDelay for interface: $($_.Name)" -OutputBox $OutputBox -Color 'Cyan' -StatusLabel $StatusLabel
            Set-RegValue -Path $interfacePath -Name "TcpNoDelay" -Value 1 -OutputBox $OutputBox -StatusLabel $StatusLabel
        }
    } catch {
        Write-Log -Message "WARNING: Could not apply TcpNoDelay to all interfaces. Details: $($_.Exception.Message)" -OutputBox $OutputBox -Color 'Orange' -StatusLabel $StatusLabel
    }

    # Flush DNS Resolver Cache
    Write-Log -Message "Flushing DNS Resolver Cache..." -OutputBox $OutputBox -Color 'Cyan' -StatusLabel $StatusLabel
    try {
        ipconfig /flushdns | Out-Null
        Write-Log -Message "DNS Resolver Cache flushed." -OutputBox $OutputBox -Color 'LimeGreen' -StatusLabel $StatusLabel
    } catch {
        Write-Log -Message "ERROR: Failed to flush DNS cache. Details: $($_.Exception.Message)" -OutputBox $OutputBox -Color 'Red' -StatusLabel $StatusLabel
    }

    Write-Log -Message "Network optimizations complete." -OutputBox $OutputBox -StatusLabel $StatusLabel
}


