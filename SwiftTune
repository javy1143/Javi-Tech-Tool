# ---- NEW v4.1: Intel/Dell Driver Diagnostic (Read-Only) ----
$Script:Tweaks += New-Tweak `
    -Id "maint_driver_diag" `
    -Name "Intel/Dell Driver Diagnostic (Read-Only)" `
    -Category "Maintenance" -Risk "Low" `
    -Description "Read-only scan: checks Intel graphics driver version against OEM thresholds, reports BIOS version, model, storage driver health, and flags any PnP devices with errors. No changes made — results logged for review and Dell Command Update action." `
    -GetState { "N-A" } `
    -Apply {
        param($BackupCtx, $OutputBox, $StatusLabel)
        Write-Log -Message "--- Intel/Dell Driver Diagnostic ---" -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel

        # System model
        try {
            $cs = Get-CimInstance -ClassName Win32_ComputerSystem -ErrorAction Stop
            Write-Log -Message "Model: $($cs.Manufacturer) $($cs.Model)" -OutputBox $OutputBox -Color Cyan -StatusLabel $StatusLabel
        } catch { }

        # BIOS
        try {
            $bios = Get-CimInstance -ClassName Win32_BIOS -ErrorAction Stop
            Write-Log -Message "BIOS: $($bios.Manufacturer) | Version: $($bios.SMBIOSBIOSVersion) | Date: $($bios.ReleaseDate)" -OutputBox $OutputBox -Color Cyan -StatusLabel $StatusLabel
            if ($bios.Manufacturer -notmatch "Dell") {
                Write-Log -Message "  NOTE: Non-Dell BIOS — verify machine identity." -OutputBox $OutputBox -Color Yellow -StatusLabel $StatusLabel
            }
        } catch { }

        # Intel display driver
        try {
            $gpuDrivers = @(Get-CimInstance -ClassName Win32_VideoController -ErrorAction Stop | Where-Object { $_.Name -match "Intel" })
            if ($gpuDrivers.Count -gt 0) {
                foreach ($gpu in $gpuDrivers) {
                    Write-Log -Message "GPU: $($gpu.Name)" -OutputBox $OutputBox -Color Cyan -StatusLabel $StatusLabel
                    Write-Log -Message "  Driver Version : $($gpu.DriverVersion)" -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel
                    Write-Log -Message "  Driver Date    : $($gpu.DriverDate)" -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel
                    $verParts = $gpu.DriverVersion -split "\."
                    if ($verParts.Count -ge 2) {
                        $major = [int]$verParts[0]; $minor = [int]$verParts[1]
                        # OEM Intel DCH drivers are 31.x+ as of 2025-2026
                        if ($major -lt 31) {
                            Write-Log -Message "  STATUS: INBOX/OUTDATED DRIVER (< 31.x)" -OutputBox $OutputBox -Color Salmon -StatusLabel $StatusLabel
                            Write-Log -Message "  ACTION: Run Dell Command Update or install Intel DCH driver from intel.com/download" -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel
                        } else {
                            Write-Log -Message "  STATUS: Driver is current OEM range (31.x+)" -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
                        }
                    }
                }
            } else {
                Write-Log -Message "No Intel GPU detected (may be AMD/NVIDIA discrete)." -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel
            }
        } catch {
            Write-Log -Message "GPU driver query failed: $($_.Exception.Message)" -OutputBox $OutputBox -Color Yellow -StatusLabel $StatusLabel
        }

        # Storage devices
        try {
            $storDevices = @(Get-PnpDevice -ErrorAction SilentlyContinue | Where-Object { $_.Class -eq "DiskDrive" -or $_.Class -eq "SCSIAdapter" } | Select-Object -First 5)
            foreach ($d in $storDevices) {
                $statusColor = if ($d.Status -eq "OK") { [System.Drawing.Color]::Silver } else { [System.Drawing.Color]::Salmon }
                Write-Log -Message "Storage: $($d.FriendlyName) | Status: $($d.Status)" -OutputBox $OutputBox -Color $statusColor -StatusLabel $StatusLabel
            }
        } catch { }

        # PnP error summary
        try {
            $problemDevices = @(Get-PnpDevice -ErrorAction SilentlyContinue | Where-Object { $_.Status -ne "OK" })
            if ($problemDevices.Count -gt 0) {
                Write-Log -Message "--- Devices with errors ($($problemDevices.Count) found) ---" -OutputBox $OutputBox -Color Gold -StatusLabel $StatusLabel
                foreach ($d in $problemDevices | Select-Object -First 10) {
                    Write-Log -Message "  [$($d.Status)] $($d.FriendlyName) | Class: $($d.Class)" -OutputBox $OutputBox -Color Salmon -StatusLabel $StatusLabel
                }
            } else {
                Write-Log -Message "No problem devices found in PnP device list." -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
            }
        } catch { }

        Write-Log -Message "Driver diagnostic complete. Review ACTION items above." -OutputBox $OutputBox -Color LimeGreen -StatusLabel $StatusLabel
    } `
    -Undo { param($ManifestPath, $OutputBox, $StatusLabel)
        Write-Log -Message "Diagnostic only — no undo needed." -OutputBox $OutputBox -Color Silver -StatusLabel $StatusLabel
    }

