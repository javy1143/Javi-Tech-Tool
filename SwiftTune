    $checkbox = $checkboxes[$category]
    switch ($category) {
        "Delete Temporary Files" { $tooltip.SetToolTip($checkbox, "Removes temporary system and user files to free up disk space. This action is irreversible.") }
        "Disable Hibernation" { $tooltip.SetToolTip($checkbox, "Disables the hibernation feature (hiberfil.sys), freeing up significant disk space. You will no longer have the 'Hibernate' power option.") }
        "Optimize Services" { $tooltip.SetToolTip($checkbox, "Adjusts the startup type of various non-essential Windows services to 'Manual' or 'Disabled' to improve system performance.") }
        "Disable Telemetry & Consumer Features" { $tooltip.SetToolTip($checkbox, "Reduces data collection by Microsoft and disables consumer-oriented features like suggested apps and ads.") }
        "Disable Activity History" { $tooltip.SetToolTip($checkbox, "Prevents Windows from collecting and syncing your activity history across devices.") }
        "Disable Game DVR" { $tooltip.SetToolTip($checkbox, "Disables the Xbox Game Bar's background recording and screenshot features, which can consume system resources.") }
        "Disable Background Apps" { $tooltip.SetToolTip($checkbox, "Prevents Universal Windows Platform (UWP) apps from running in the background when not actively in use.") }
        "Disable Storage Sense" { $tooltip.SetToolTip($checkbox, "Turns off Storage Sense, Windows' automatic disk cleanup feature.") }
        "Disable WiFi Sense" { $tooltip.SetToolTip($checkbox, "Disables features that automatically connect to open Wi-Fi hotspots and share Wi-Fi network credentials.") }
        "Disable Teredo" { $tooltip.SetToolTip($checkbox, "Disables the Teredo tunneling interface, which is primarily used for IPv6 connectivity over IPv4 networks. Can improve network performance in some cases.") }
        "Disable Recall (Windows 11)" { $tooltip.SetToolTip($checkbox, "Disables the Windows Recall feature, which captures screenshots of your activity. This requires a system restart to take full effect.") }
        "Debloat Microsoft Edge" { $tooltip.SetToolTip($checkbox, "Applies registry tweaks to disable various non-essential features and reporting in Microsoft Edge.") }
        "Adobe Debloat" { $tooltip.SetToolTip($checkbox, "Attempts to disable or rename non-essential Adobe background services and processes.") }
        "Network Optimizations" { $tooltip.SetToolTip($checkbox, "Optimizes network settings by disabling Nagle's algorithm (TcpNoDelay) and flushing the DNS cache, which can reduce latency.") } # NEW: Tooltip for Network Optimizations
        default { $tooltip.SetToolTip($checkbox, "No detailed information available for this tweak.") }
    }
}

